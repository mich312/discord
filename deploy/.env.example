# Copy to deploy/.env and fill in. deploy/.env is gitignored — never commit it.

# The public domain you serve from. An A/AAAA record for it must point at this
# VM's IP before you start the stack (Caddy needs it to pass the ACME challenge).
# Also becomes RP_ID/RP_ORIGIN — passkeys are bound to this exact origin.
CADDY_DOMAIN=chat.example.org

# Keep Web Push subscriptions alive across restarts. Generate once (the raw
# 32-byte P-256 scalar lives at DER offset 7 — count from the front, not
# `tail -c 32`, which trails the curve OID and yields a malformed key):
#   openssl ecparam -genkey -name prime256v1 | openssl ec -no_public \
#     -outform DER 2>/dev/null | tail -c +8 | head -c 32 | basenc --base64url | tr -d '='
VAPID_PRIVATE_KEY=

# --- Voice / TURN ----------------------------------------------------------
# A public STUN server (the default) only connects callers on cone NATs. For
# reliable calls across the internet you need a TURN relay. Recommended: run
# the bundled coturn (add -f deploy/docker-compose.turn.yml) and set the two
# vars below — the relay then mints a short-lived credential per user, so no
# shared password is ever shipped to clients. TURN forwards ciphertext only.
#
# TURN_SECRET is shared between coturn and the relay. Generate: openssl rand -hex 32
TURN_SECRET=
# What clients dial. Point the host at your server; keep udp + tcp:
#   turn:chat.example.org:3478?transport=udp,turn:chat.example.org:3478?transport=tcp
TURN_URLS=
# Optional: credential lifetime in seconds (default 3600) and coturn realm.
TURN_TTL=3600
TURN_REALM=quorum

# Alternative to the above: a verbatim JSON array of RTCIceServer objects
# (e.g. a managed TURN provider with static credentials). Wins over TURN_* if
# set. Leave empty to use TURN_* / the default STUN.
#   ICE_SERVERS=[{"urls":"turn:turn.example.org:3478","username":"u","credential":"p"}]
ICE_SERVERS=
